# ── Backend Environment Variables ──────────────────────────
# Copy this file to .env and adjust values for local development.

# App
APP_NAME=Trans Comarapa API
APP_VERSION=1.0.0
DEBUG=true
TIMEZONE=America/La_Paz
LOG_LEVEL=INFO
TESTING=false

# Database
DATABASE_URL=mysql+pymysql://root:Passw0rd!@localhost:3308/trans_comarapa
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=change-me-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_BLACKLIST_EXPIRE_SECONDS=86400

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REGISTER=3/minute
RATE_LIMIT_AUTH_REFRESH=10/minute
RATE_LIMIT_DEFAULT=100/minute

# Business logic
SEAT_LOCK_TTL_SECONDS=300
TRIP_MIN_DEPARTURE_BUFFER_MINUTES=30
TRIP_CONFLICT_BUFFER_HOURS=2
CASH_REGISTER_HISTORY_DAYS=7

# Defaults (seeding only)
EMAIL_DOMAIN=transcomarapa.com
DEFAULT_OWNER_PASSWORD=socio123
DEFAULT_CLIENT_PASSWORD=123456
