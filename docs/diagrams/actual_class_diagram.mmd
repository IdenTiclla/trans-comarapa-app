    %% Polymorphic inheritance
    Person <|-- Administrator
    Person <|-- Secretary
    Person <|-- Driver
    Person <|-- Assistant
    Person <|-- Client

    %% User-Person 1:1
    User "1" -- "1" Person : has

    %% Office
    Office "*" -- "1" Location : located at
    Office "1" -- "*" Secretary : employs

    %% Routes
    Location "1" -- "*" Route : origin
    Location "1" -- "*" Route : destination
    Route "1" -- "*" RouteSchedule : schedules
    Route "1" -- "*" Trip : trips

    %% Bus
    Bus "1" -- "*" Seat : contains
    Bus "1" -- "*" Trip : assigned to

    %% Trip
    Trip "*" -- "1" Driver : driven by
    Trip "*" -- "0..1" Assistant : assisted by
    Trip "*" -- "1" Secretary : dispatched by

    %% Ticket
    Trip "1" -- "*" Ticket : has
    Ticket "*" -- "1" Client : purchased by
    Ticket "*" -- "1" Seat : occupies
    Ticket "*" -- "1" Secretary : sold by
    Ticket "1" -- "*" TicketStateHistory : history

    %% Package
    Trip "1" -- "*" Package : transports
    Package "*" -- "1" Client : sender
    Package "*" -- "1" Client : recipient
    Package "*" -- "1" Secretary : registered by
    Package "1" -- "*" PackageItem : items
    Package "1" -- "*" PackageStateHistory : history

    %% Cash Register
    Office "1" -- "*" CashRegister : has
    CashRegister "1" -- "*" CashTransaction : records
    CashRegister "*" -- "1" User : opened by
    CashRegister "*" -- "0..1" User : closed by

    %% Activity
    Activity "*" -- "1" User : performed by
