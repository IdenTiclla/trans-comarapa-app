# ── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=Passw0rd!

# ── Backend ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-string-in-production
DEBUG=true
TESTING=false
LOG_LEVEL=INFO

# Database (used by backend directly)
DATABASE_URL=mysql+pymysql://root:Passw0rd!@localhost:3308/trans_comarapa

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_BLACKLIST_EXPIRE_SECONDS=86400

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# ── Frontend ──────────────────────────────────────────────
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Docker targets ────────────────────────────────────────
BACKEND_TARGET=development
FRONTEND_TARGET=development
